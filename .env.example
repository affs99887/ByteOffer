# ByteOffer environment (see docs/design/architecture.md §11). Copy to .env and fill real values.

# ---- Database (PostgreSQL; e.g. Neon) ----
# DATABASE_URL = pooled connection (PgBouncer) used by the app at runtime
# DIRECT_URL   = non-pooled connection used by `prisma migrate`
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/byteoffer?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/byteoffer?sslmode=require"

# ---- Auth.js (v5) ----
# Generate a secret: `openssl rand -base64 33`
AUTH_SECRET="replace-with-a-32+char-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- Stripe ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PK="pk_test_..."
STRIPE_PRICE_PLUS_MONTHLY="price_..."
STRIPE_PRICE_PLUS_YEARLY="price_..."

# ---- Email (Resend) ----
# 邮箱验证策略由是否配置 RESEND_API_KEY 决定（占位/含 dummy·placeholder·changeme 视为未配置）：
#   不配置 = 注册免验证、直接可用（注册后 emailVerified 立即置为已验证，可直接登录；找回密码提示
#            “邮件服务未配置，请联系管理员”；未验证的历史账号也可登录，部署不会被锁死）。
#   配置   = 严格邮箱验证（注册后需点邮件链接才能登录，提供“重新发送”；支持自助找回密码）。
# 上线若要求邮箱验证/自助找回，必须配置 RESEND_API_KEY 与 EMAIL_FROM。
RESEND_API_KEY="re_..."
EMAIL_FROM="ByteOffer <noreply@example.com>"

# ---- Bootstrap admin (used by prisma/seed.ts) ----
ADMIN_EMAIL="admin@byteoffer.dev"
ADMIN_PASSWORD="change-me-strong-password"

# ---- Optional ----
SENTRY_DSN=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Shared secret for the nightly reconciliation cron (GET/POST /api/cron/reconcile).
# Send it as `Authorization: Bearer <secret>` or `x-cron-secret: <secret>`. Vercel Cron sends the
# Authorization header automatically when CRON_SECRET is set. Leave empty to DISABLE the route (404).
CRON_SECRET=""
